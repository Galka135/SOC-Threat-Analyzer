# Copy this file to  .streamlit/secrets.toml  and fill in your keys.
# secrets.toml itself is git-ignored and must NEVER be committed.
# Every key is OPTIONAL — a source without a key is simply skipped.

VT_API_KEY     = ""   # https://www.virustotal.com  (API key)
ABUSE_API_KEY  = ""   # https://www.abuseipdb.com   (account -> API)
IPQS_KEY       = ""   # https://www.ipqualityscore.com
GREYNOISE_KEY  = ""   # https://viz.greynoise.io    (community API)
VPNAPI_KEY     = ""   # https://vpnapi.io
PROXYCHECK_KEY = ""   # https://proxycheck.io       (works keyless too)
OTX_API_KEY    = ""   # https://otx.alienvault.com  (Settings -> API)
CENSYS_PAT     = ""   # https://search.censys.io    ("id:secret" or PAT)
IPINFO_KEY     = ""   # https://ipinfo.io  (also accepts IPINFO_TOKEN / IPINFO_API_KEY)
CRIMINALIP_KEY = ""   # https://www.criminalip.io  (My Account -> API Key)
# THREATFOX_AUTH_KEY optional — free at https://auth.abuse.ch (raises rate limits)
THREATFOX_AUTH_KEY = ""
# ── AI analyst (optional) — Gemini is tried first, Claude is the fallback ──
GEMINI_API_KEY = ""      # https://aistudio.google.com/apikey (also accepts GEMINI_KEY / GOOGLE_API_KEY)
ANTHROPIC_API_KEY = ""   # https://platform.claude.com (also accepts CLAUDE_API_KEY / CLAUDE_KEY)
